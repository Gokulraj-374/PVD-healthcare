{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Information captured from the lead generation form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the lead" },
        "email": { "type": "string", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "courseInterest": { "type": "string", "description": "Course they are interested in" },
        "message": { "type": "string", "description": "Optional message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission" }
      },
      "required": ["name", "email", "phone", "courseInterest", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of student inquiries."
    }
  }
}
